# Copy to .env.local for local dev; set the same vars in Vercel project settings.
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — from Project Settings > API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=YOUR-ANON-KEY

# Days after send() before follow-up is due (default 7)
FOLLOW_UP_DAYS=7
